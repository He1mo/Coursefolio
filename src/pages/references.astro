---
import SiteLayout from '../layouts/SiteLayout.astro';
import { legacyPages } from '../data/legacy-content';

const page = legacyPages.find((item) => item.slug === 'references');
---

<SiteLayout title="参考资料" active="参考资料">
  <article class="content-panel">
    <h1>参考资料</h1>
    <div class="empty-state" set:html={page?.content || '<p>原 WordPress XML 中未保存该栏目的正文内容。</p>'} />
  </article>
</SiteLayout>
