---
import SiteLayout from '../layouts/SiteLayout.astro';
import { legacyPages } from '../data/legacy-content';

const page = legacyPages.find((item) => item.slug === 'syllabus');
---

<SiteLayout title="课程大纲" active="课程大纲">
  <article class="content-panel">
    <h1>课程大纲</h1>
    <div class="legacy-content syllabus-content" set:html={page?.content || '<p>暂无可恢复正文。</p>'} />
  </article>
</SiteLayout>
